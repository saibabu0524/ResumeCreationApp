# =============================================================================
# Android Compose Template — Environment Configuration
# =============================================================================
# Copy this file to `local.properties` at the project root and fill in values.
# local.properties is gitignored and MUST NEVER be committed.
# In CI, these values are injected as encrypted environment secrets.
# =============================================================================

# Base URLs per flavor
DEV_BASE_URL=https://dev-api.example.com/v1/
STAGING_BASE_URL=https://staging-api.example.com/v1/
PROD_BASE_URL=https://api.example.com/v1/

# API Keys (if needed)
# API_KEY=your_api_key_here

# Signing Config (for release builds)
# KEYSTORE_FILE=keystore.jks
# KEYSTORE_PASSWORD=
# KEY_ALIAS=
# KEY_PASSWORD=
