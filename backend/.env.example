# ─────────────────────────────────────────────────────────────────────────────
# FastAPI Production Template — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="FastAPI Production Template"
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=info                   # debug | info | warning | error | critical
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Production: Vercel frontend lives at app.resumetailor.in
ALLOWED_ORIGINS=https://app.resumetailor.in,http://localhost:3000,http://localhost:8080

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=20/minute

# ── Redis / ARQ ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / LLM providers ────────────────────────────────────────────────────────
# Gemini (default provider for /resume/tailor)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama — local or remote Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_API_KEY=

# OpenAI-compatible cloud (e.g. Kimi / Moonshot)
CLOUD_API_KEY=
CLOUD_BASE_URL=https://api.moonshot.cn/v1
CLOUD_MODEL=moonshot-v1-8k

# ── Resume processing ─────────────────────────────────────────────────────────
LLM_RETRY_ATTEMPTS=2
