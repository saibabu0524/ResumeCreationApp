#!/bin/sh
# ─── Pre-commit Git Hook — Ktlint Format Check ────────────────────────────
#
# This hook runs Ktlint on staged Kotlin files before every commit.
# Unformatted code cannot be committed.
#
# Installation:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or set up via git config:
#   git config core.hooksPath scripts/hooks

echo "🔍 Running Ktlint format check on staged files..."

# Get list of staged Kotlin files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$' | grep -v 'build/' | grep -v 'generated/')

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No Kotlin files staged — skipping Ktlint check."
    exit 0
fi

# Run Ktlint check
./gradlew ktlintCheck --daemon --quiet 2>/dev/null

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ Ktlint check FAILED. Unformatted code cannot be committed."
    echo ""
    echo "Fix formatting by running:"
    echo "  ./gradlew ktlintFormat"
    echo ""
    echo "Then re-stage and commit."
    exit 1
fi

echo "✅ Ktlint check passed."
exit 0
